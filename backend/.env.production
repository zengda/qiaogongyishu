FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=替换为随机32位字符串
JWT_SECRET_KEY=替换为另一个随机32位字符串

SQLALCHEMY_DATABASE_URI=sqlite:////app/instance/qiaogongyishu.db

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

PRODUCTION_DOMAIN=qgys.rongyun.online

STORAGE_TYPE=oss
LOCAL_UPLOAD_PATH=/app/uploads
LOCAL_BASE_URL=https://qgys.rongyun.online/uploads

OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou
