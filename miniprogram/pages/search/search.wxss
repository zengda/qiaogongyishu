.container {
  padding-bottom: 40rpx;
}

.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
}

.search-input-wrap {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
}

.search-input {
  font-size: 28rpx;
  width: 100%;
}

.cancel-btn {
  font-size: 28rpx;
  color: #1A6D5C;
  margin-left: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.clear-btn {
  font-size: 24rpx;
  color: #999;
}

.history-list, .hot-list {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
  gap: 16rpx;
}

.history-item, .hot-item {
  padding: 14rpx 28rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.hot-item {
  background: #fff;
  border: 1rpx solid #1A6D5C;
  color: #1A6D5C;
}

.result-header {
  padding: 20rpx 24rpx;
  background: #fff;
}

.result-count {
  font-size: 26rpx;
  color: #999;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 24rpx;
  justify-content: space-between;
}

.product-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-image {
  width: 100%;
  height: 280rpx;
}

.product-info {
  padding: 20rpx;
}

.product-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: -webkit-box;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.product-meta {
  margin-top: 12rpx;
}

.product-area {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
  display: block;
}

.loading-center {
  text-align: center;
  padding: 120rpx 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.load-more, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.product-image-placeholder {
  width: 100%;
  height: 280rpx;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  color: #ccc;
}