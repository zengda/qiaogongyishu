.container {
  padding: 32rpx 24rpx;
  padding-bottom: 120rpx;
}

.form-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.header-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
}

.product-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.card-value {
  font-size: 30rpx;
  color: #333;
  margin-top: 8rpx;
  display: block;
}

.form-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.required {
  color: #ff4d4f;
}

.form-input {
  font-size: 30rpx;
  color: #333;
}

.form-picker {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-text {
  font-size: 30rpx;
  color: #999;
}

.submit-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #1A6D5C;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: env(safe-area-inset-bottom);
}

.submit-btn.disabled {
  background: #ccc;
}

.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  text-align: center;
}

.modal-icon {
  font-size: 80rpx;
  color: #1A6D5C;
  display: block;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-top: 24rpx;
  display: block;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
  display: block;
}

.modal-btn {
  margin-top: 40rpx;
  height: 80rpx;
  background: #1A6D5C;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn text {
  color: #fff;
  font-size: 30rpx;
}