<view class="container">
  <view class="skeleton-wrap" wx:if="{{initialLoading}}">
    <view class="skeleton skeleton-banner"></view>
    <view class="skeleton skeleton-search"></view>
    <view class="skeleton-nav">
      <view class="skeleton skeleton-nav-item"></view>
      <view class="skeleton skeleton-nav-item"></view>
      <view class="skeleton skeleton-nav-item"></view>
      <view class="skeleton skeleton-nav-item"></view>
      <view class="skeleton skeleton-nav-item"></view>
    </view>
    <view class="skeleton-product-list">
      <view class="skeleton skeleton-card" wx:for="{{4}}" wx:key="*this">
        <view class="skeleton skeleton-img"></view>
        <view class="skeleton skeleton-text"></view>
        <view class="skeleton skeleton-text-short"></view>
      </view>
    </view>
  </view>

  <block wx:else>
  <banner-component banners="{{banners}}" bind:click="onBannerClick"></banner-component>
  
  <view class="search-bar" bindtap="onSearchClick">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索图纸型号、名称</text>
    </view>
  </view>
  
  <category-nav 
    categories="{{categories}}" 
    active-category="{{activeCategory}}" 
    show-style-filter="{{showStyleFilter}}"
    tags="{{tags}}"
    active-tag="{{activeTag}}"
    bind:change="onCategoryChange" 
    bind:styleTap="onStyleTap"
    bind:tagChange="onTagChange"
  ></category-nav>
  
  <view class="product-list">
    <view 
      class="product-card" 
      wx:for="{{products}}" 
      wx:key="id" 
      bindtap="onProductClick" 
      data-id="{{item.id}}"
    >
      <view class="product-image-wrapper">
        <image wx:if="{{item.cover_image}}" class="product-image" src="{{item.cover_image}}" mode="aspectFill" lazy-load />
        <view wx:else class="product-image-placeholder">
          <text class="placeholder-icon">🏠</text>
        </view>
      </view>
      <view class="product-info">
        <text class="product-title">{{item.title}}</text>
        <view class="product-meta">
          <text class="product-area">{{item.floor_area || item.building_area}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="load-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  
  <view class="no-more" wx:if="{{!loading && !hasMore}}">
    <text>没有更多了</text>
  </view>
  </block>
</view>