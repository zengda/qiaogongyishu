.container {
  padding: 0 0 40rpx 0;
  background: #f7f8fa;
}

.search-bar {
  padding: 20rpx 24rpx;
  background: #fff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

.product-list {
  padding: 24rpx;
  background: #f7f8fa;
}

.product-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
}

.product-card.left {
  float: left;
  margin-right: 20rpx;
}

.product-card.right {
  float: right;
  margin-right: 0;
}

.product-image-wrapper {
  width: 100%;
  height: 280rpx;
}

.product-image {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
}

.product-image-placeholder {
  width: 100%;
  height: 100%;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  color: #ccc;
}

.product-info {
  padding: 20rpx;
}

.product-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: -webkit-box;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.product-meta {
  margin-top: 12rpx;
}

.product-area {
  font-size: 24rpx;
  color: #999;
}

.load-more, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
  background: #f7f8fa;
}

.skeleton-wrap {
  padding: 0;
}

.skeleton {
  background: linear-gradient(90deg, #eee 25%, #f5f5f5 50%, #eee 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: 12rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton-banner {
  width: 100%;
  height: 360rpx;
  border-radius: 0;
}

.skeleton-search {
  width: calc(100% - 48rpx);
  height: 72rpx;
  margin: 20rpx 24rpx;
}

.skeleton-nav {
  display: flex;
  padding: 16rpx 24rpx;
  justify-content: space-between;
  background: #fff;
}

.skeleton-nav-item {
  width: 90rpx;
  height: 36rpx;
}

.skeleton-product-list {
  padding: 24rpx;
  overflow: hidden;
}

.skeleton-card {
  float: left;
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-card:nth-child(2n) {
  margin-right: 0;
}

.skeleton-img {
  width: 100%;
  height: 280rpx;
  border-radius: 0;
}

.skeleton-text {
  height: 28rpx;
  margin: 20rpx 20rpx 0;
}

.skeleton-text-short {
  height: 22rpx;
  width: 60%;
  margin: 12rpx 20rpx 20rpx;
}