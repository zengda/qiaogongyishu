.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  background-color: #ffffff;
  padding: 48rpx 40rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.content {
  flex: 1;
  padding: 40rpx;
}

.agreement-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
}