.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.25s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 56rpx 0;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12), 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  animation: slideUp 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background-color: rgba(0, 0, 0, 0.12);
  margin: 0 auto 24rpx;
}

.modal-header {
  text-align: center;
  margin-bottom: 28rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

.modal-content {
  margin-bottom: 40rpx;
  line-height: 1.85;
  color: #555555;
  font-size: 28rpx;
  text-align: justify;
  max-height: 360rpx;
  overflow-y: auto;
}

.content-text {
  color: #555555;
}

.content-highlight {
  color: #1a1a1a;
  font-weight: 600;
}

.content-link {
  color: #07c160;
  font-weight: 500;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  padding-bottom: 16rpx;
}

.btn {
  flex: 1;
  max-width: 240rpx;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
  position: relative;
  overflow: hidden;
}

.btn::after {
  border: none;
}

.btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-reject {
  background-color: #f5f5f5;
  color: #666666;
}

.btn-reject:active {
  background-color: #e8e8e8;
}

.btn-agree {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.32);
}

.btn-agree:active {
  background: linear-gradient(135deg, #06ad56 0%, #0ea375 100%);
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.24);
}