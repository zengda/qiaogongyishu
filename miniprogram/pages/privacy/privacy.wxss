.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f7f8fa;
}

.header {
  background: linear-gradient(135deg, #1A6D5C 0%, #2A8F7A 100%);
  padding: 48rpx 32rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.content {
  flex: 1;
  padding: 32rpx;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1A6D5C;
  margin-bottom: 24rpx;
}

.section-content {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.footer {
  padding: 32rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
}

.agree-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1A6D5C 0%, #2A8F7A 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.agree-btn::after {
  border: none;
}

.disagree-btn {
  width: 100%;
  height: 80rpx;
  background-color: transparent;
  color: #999;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.disagree-btn::after {
  border: none;
}