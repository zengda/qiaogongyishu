page {
  background-color: #F7F8FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 0 24rpx;
}

.btn-primary {
  background-color: #1A6D5C;
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 24rpx 48rpx;
  border: none;
}

.btn-secondary {
  background-color: #F5A623;
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 24rpx 48rpx;
  border: none;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.text-primary {
  color: #1A6D5C;
}

.text-secondary {
  color: #F5A623;
}

.text-gray {
  color: #999;
}

.text-sm {
  font-size: 24rpx;
}

.text-md {
  font-size: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}