.category-section {
  background: #fff;
  padding: 16rpx 0;
  position: relative;
}

.category-list {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.category-item {
  display: inline-block;
  padding: 8rpx 0;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
  white-space: nowrap;
  border-bottom: 4rpx solid transparent;
  font-weight: 500;
}

.category-item.active {
  color: #1A6D5C;
  border-bottom-color: #1A6D5C;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #1A6D5C;
  font-weight: 500;
}

.filter-btn.active {
  color: #1A6D5C;
  font-weight: 600;
}

.filter-icon {
  width: 28rpx;
  height: 28rpx;
}

.style-filter-wrapper {
  position: absolute;
  top: 100%;
  right: 0;
  z-index: 100;
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  transform: translateY(-10rpx);
  transition: all 0.3s ease;
}

.style-filter-wrapper.expanded {
  max-height: 500rpx;
  opacity: 1;
  transform: translateY(0);
}

.style-filter-content {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  padding: 8rpx 0;
  min-width: 180rpx;
  margin-right: 24rpx;
}

.style-tag {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
  text-align: center;
}

.style-tag.active {
  color: #1A6D5C;
  font-weight: 500;
}