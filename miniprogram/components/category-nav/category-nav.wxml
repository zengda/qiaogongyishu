<view class="category-section">
  <view class="category-list">
    <view 
      class="category-item {{activeCategory === item.id ? 'active' : ''}}"
      wx:for="{{categories}}" 
      wx:key="id"
      bindtap="onCategoryTap"
      data-id="{{item.id}}"
    >
      <text>{{item.name}}</text>
    </view>
    <view 
      class="category-item filter-btn {{showStyleFilter ? 'active' : ''}}"
      bindtap="onStyleTap"
    >
      <text>🏷风格</text>
    </view>
  </view>
  
  <view class="style-filter-wrapper {{showStyleFilter ? 'expanded' : ''}}">
    <view class="style-filter-content">
      <view 
        class="style-tag {{activeTag === item.id ? 'active' : ''}}"
        wx:for="{{tags}}" 
        wx:key="id"
        bindtap="onTagTap"
        data-id="{{item.id}}"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>
</view>