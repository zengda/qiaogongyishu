.style-filter-container {
  overflow: hidden;
}

.style-filter {
  background: #fff;
  transition: all 0.3s ease;
}

.style-filter.show {
  max-height: 160rpx;
  opacity: 1;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.style-filter.hide {
  max-height: 0;
  opacity: 0;
  padding: 0 24rpx;
}

.filter-content {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.filter-item {
  padding: 16rpx 28rpx;
  border-radius: 28rpx;
  background: #f5f5f5;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.filter-item.active {
  background: #1A6D5C;
  color: #fff;
}