<view class="style-filter-container">
  <view class="style-filter {{visible ? 'show' : 'hide'}}">
    <view class="filter-content">
      <view 
        class="filter-item {{activeTag === item.id ? 'active' : ''}}"
        wx:for="{{tags}}" 
        wx:key="id"
        bindtap="onTagTap"
        data-id="{{item.id}}"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>
</view>